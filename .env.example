# OncoMOA Biomarker Agent — Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── LLM Configuration ────────────────────────────────────────────────────────
# Backend selection: "gemini" | "ollama" | "meditron" | "auto" (default: auto)
# "auto" uses smart drug-class routing (Merck/bispecific/ADC → gemini, else → meditron)
LLM_BACKEND=auto

# Google Gemini API key (required only if using gemini backend)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama endpoint (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# ─── Optional API Keys (all data sources are free/public) ─────────────────────
# NCBI E-utilities API key (optional, increases rate limit from 3 to 10 req/sec)
NCBI_API_KEY=

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Cache ────────────────────────────────────────────────────────────────────
# Cache directory (relative to project root)
CACHE_DIR=.cache/oncomoa

# Cache TTL in seconds (default: 7 days = 604800)
CACHE_TTL=604800
